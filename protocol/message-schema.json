{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/polyakovin/agentic-crew/protocol/message-schema.json",
  "title": "Agentic Crew Message",
  "type": "object",
  "required": ["message_type", "task_id", "specialist", "status"],
  "properties": {
    "message_type": {
      "type": "string",
      "enum": [
        "task_brief",
        "specialist_report",
        "review_finding",
        "decision_record",
        "handoff_packet"
      ]
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "specialist": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["complete", "blocked", "needs-review", "out-of-scope"]
    },
    "summary": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "ref"],
        "properties": {
          "kind": {
            "type": "string"
          },
          "ref": {
            "type": "string"
          },
          "note": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "handoff": {
      "type": "object"
    }
  },
  "additionalProperties": true
}

